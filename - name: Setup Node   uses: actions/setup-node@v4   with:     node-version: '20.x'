# Funktion: Permutationen erzeugen
function Get-Permutationen {
    param([array]$arr)

    if ($arr.Count -eq 1) { return ,@($arr) }

    $result = @(0xFFFFFFFF)
    foreach ($i in 0..($arr.Count - 1)) {
        $rest = $arr[0..($i-1)] + $arr[($i+1)..($arr.Count-1)]
        foreach ($perm in Get-Permutationen $rest) {
            $result += ,@($arr[$i]) + $perm
        }
    }
    return $result
}

