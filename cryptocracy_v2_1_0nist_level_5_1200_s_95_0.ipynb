import numpy as np
import matplotlib.pyplot as plt
from mpl_toolkits.mplot3d import Axes3D

def plot_3d_timewave(amplitude=2, frequency=0.5):
    t = np.linspace(0, 4*np.pi, 500)
    x = amplitude * np.cos(frequency * t)
    y = amplitude * np.sin(frequency * t)
    z = t / (2*np.pi)

    fig = plt.figure(figsize=(12, 8))
    ax = fig.add_subplot(111, projection='3d')
    ax.plot(x, y, z, lw=0.5, color='purple')
    ax.set_title("4D-Zeitwelle (3D-Projektion)", fontsize=14)
    ax.set_xlabel("Realteil (Kosinus)")
    ax.set_ylabel("Imaginärteil (Sinus)")
    ax.set_zlabel("Zeit (normiert)")
    plt.show()
