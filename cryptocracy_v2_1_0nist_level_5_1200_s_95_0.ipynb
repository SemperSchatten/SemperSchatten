        "import sqlite3\n",
        "import logging\n",
        "\n",
        "class DatabaseManager:\n",
        "    def __init__(self, db_path):\n",
        "        self.connection = sqlite3.connect(db_path)\n",
        "        self.cursor = self.connection.cursor()\n",
        "\n",
        "    def execute_query(self, query, params=None):\n",
        "        try:\n",
        "            if params:\n",
        "                self.cursor.execute(query, params)\n",
        "            else:\n",
        "                self.cursor.execute(query)\n",
        "            self.connection.commit()\n",
        "            logging.info(\"Abfrage erfolgreich ausgeführt.\")\n",
        "        except sqlite3.Error as e:\n",
        "            logging.error(f\"Datenbankfehler: {e}\")\n",
        "\n",
        "    def fetch_results(self, query, params=None):\n",
        "        try:\n",
        "            if params:\n",
        "                self.cursor.execute(query, params)\n",
        "            else:\n",
        "                self.cursor.execute(query)\n",
        "            results = self.cursor.fetchall()\n",
        "            logging.info(\"Ergebnisse erfolgreich abgerufen.\")\n",
        "            return results\n",
        "        except sqlite3.Error as e:\n",
        "            logging.error(f\"Datenbankfehler: {e}\")\n",
        "            return []\n",
        "\n",
        "    def insert_data(self, data):\n",
        "        # Annahme: 'data' enthält 'table_data' mit einem 'Überschrift'-Key\n",
        "        if \"table_data\" in data and \"Überschrift\" in data[\"table_data\"]:\n",
        "            for title in data[\"table_data\"][\"Überschrift\"]:\n",
        "                self.execute_query(\"INSERT INTO table_data (title) VALUES (?)\", (title,))\n",
        "\n",
        "    def close_connection(self):\n",
        "        self.connection.close()"
      ],
