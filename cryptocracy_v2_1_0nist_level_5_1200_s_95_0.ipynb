        "class QuantumQLearning:\n",
        "    def __init__(self, state_size, action_size):\n",
        "        self.q_table = np.zeros((state_size, action_size))\n",
        "        self.gamma = 0.95  # Diskontfaktor\n",
        "        self.alpha = 0.1   # Lernrate\n",
