17.5 JavaScript: QuantumComputer-Klasse (ergänzt)
class QuantumComputer {
    constructor() {
        this.qubits = [];
        this.entanglementMap = new Map();
    }

    initialize(numQubits) {
        this.qubits = Array(numQubits).fill().map(() => ({
            amplitude: { real: 1, imaginary: 0 }, // Initialzustand |0>
            phase: 0 // Zusätzliche Phase, falls benötigt
        }));
        console.log(`QuantumComputer initialisiert mit ${numQubits} Qubits.`);
    }

    // Beispiel für ein Hadamard-Gatter
    hadamardGate(qubitIndex) {
        if (qubitIndex < 0 || qubitIndex >= this.qubits.length) {
            console.error("Ungültiger Qubit-Index.");
            return;
        }
        const q = this.qubits[qubitIndex];
        const oldReal = q.amplitude.real;
        const oldImaginary = q.amplitude.imaginary;

        q.amplitude = {
            real: (oldReal + oldImaginary) / Math.sqrt(2),
            imaginary: (oldReal - oldImaginary) / Math.sqrt(2)
        };
        console.log(`Hadamard-Gatter auf Qubit ${qubitIndex} angewendet.`);
    }

    // Beispiel für ein CNOT-Gatter
    cnotGate(controlQubitIndex, targetQubitIndex) {
        if (controlQubitIndex < 0 || controlQubitIndex >= this.qubits.length ||
            targetQubitIndex < 0 || targetQubitIndex >= this.qubits.length ||
            controlQubitIndex === targetQubitIndex) {
            console.error("Ungültige Qubit-Indizes für CNOT-Gatter.");
            return;
        }
        console.log(`CNOT-Gatter von Qubit ${controlQubitIndex} auf Qubit ${targetQubitIndex} angewendet.`);
    }

    // Beispiel für Messung (kollabiert Zustand)
    measure(qubitIndex) {
        if (qubitIndex < 0 || qubitIndex >= this.qubits.length) {
            console.error("Ungültiger Qubit-Index zum Messen.");
            return;
        }
        const q = this.qubits[qubitIndex];
        const probabilityZero = Math.abs(q.amplitude.real)**2 + Math.abs(q.amplitude.imaginary)**2;
        const outcome = Math.random() < probabilityZero ? 0 : 1;

        q.amplitude = { real: (outcome === 0 ? 1 : 0), imaginary: 0 };
        console.log(`Qubit ${qubitIndex} gemessen: ${outcome}`);
        return outcome;
    }

    // Funktion zur Visualisierung des Zustands (vereinfacht)
    displayState() {
        this.qubits.forEach((q, i) => {
            console.log(`Qubit ${i}: Amplitude (Real: ${q.amplitude.real.toFixed(2)}, Imaginär: ${q.amplitude.imaginary.toFixed(2)}), Phase: ${q.phase.toFixed(2)}`);
        });
    }
}

