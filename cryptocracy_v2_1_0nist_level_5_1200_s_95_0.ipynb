import sqlite3
import logging

class DatabaseManager:
    def __init__(self, db_path):
        self.connection = sqlite3.connect(db_path)
        self.cursor = self.connection.cursor()

    def execute_query(self, query, params=None):
        try:
            if params:
                self.cursor.execute(query, params)
            else:
                self.cursor.execute(query)
            self.connection.commit()
            logging.info("Abfrage erfolgreich ausgeführt.")
        except sqlite3.Error as e:
            logging.error(f"Datenbankfehler: {e}")

    def fetch_results(self, query, params=None):
        try:
            if params:
                self.cursor.execute(query, params)
            else:
                self.cursor.execute(query)
            results = self.cursor.fetchall()
            logging.info("Ergebnisse erfolgreich abgerufen.")
            return results
        except sqlite3.Error as e:
            logging.error(f"Datenbankfehler: {e}")
            return []

    def insert_data(self, data):
        # Annahme: 'data' enthält 'table_data' mit einem 'Überschrift'-Key
        if "table_data" in data and "Überschrift" in data["table_data"]:
            for title in data["table_data"]["Überschrift"]:
                self.execute_query("INSERT INTO table_data (title) VALUES (?)", (title,))

    def close_connection(self):
        self.connection.close()
17.4 JavaScript: Hypercube-Klasse mit Namespace-Integration
class Namespace {
    constructor() {
        this.namespace = new Map();
    }

    addToken(token, tags) {
        if (!this.namespace.has(token)) {
            this.namespace.set(token, new Set(tags));
        } else {
            let existingTags = this.namespace.get(token);
            tags.forEach(tag => existingTags.add(tag));
        }
    }

    getTokenTags(token) {
        return this.namespace.get(token) || new Set();
    }

    findTokensByTag(tag) {
        let matchingTokens = [];
        for (let [token, tags] of this.namespace.entries()) {
            if (tags.has(tag)) {
                matchingTokens.push(token);
            }
        }
        return matchingTokens;
    }

    displayNamespace() {
        console.log("Namespace:");
        for (const [token, tags] of this.namespace.entries()) {
            console.log(`Token: ${token}, Tags: ${Array.from(tags).join(", ")}`);
        }
    }
}

class Hypercube {
    constructor(dimensions) {
        this.dimensions = dimensions;
        this.states = [];
        this.namespace = new Namespace();
    }

    generateState(t) {
        let stateVector = Array(this.dimensions).fill().map(() => Math.random());
        let stateName = `state_t${t}`;
        this.namespace.addToken(stateName, ['vector', `time_${t}`]);
        this.states.push(stateVector);
        console.log(`Generated state at t=${t}:`, stateVector);
    }

    measureState(t) {
        let stateName = `state_t${t}`;
        let stateVector = this.namespace.getTokenTags(stateName);
        if (stateVector.size > 0) {
            console.log(`Measured state at t=${t}:`, stateVector);
        } else {
            console.log(`State at t=${t} not found.`);
        }
    }

    displayStates() {
        this.namespace.displayNamespace();
    }
}

