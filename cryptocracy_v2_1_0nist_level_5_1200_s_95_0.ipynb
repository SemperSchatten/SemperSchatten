import numpy as np

class QuantumQLearning:
    def __init__(self, state_size, action_size):
        self.q_table = np.zeros((state_size, action_size))
        self.gamma = 0.95  # Diskontfaktor
        self.alpha = 0.1   # Lernrate

    def update(self, state, action, reward, next_state):
        """Quanten-inspirierte Aktualisierung"""
        delta = reward + self.gamma*np.max(self.q_table[next_state]) - self.q_table[state, action]
        self.q_table[state, action] += self.alpha * delta * self._quantum_fluctuation()

    def _quantum_fluctuation(self):
        """Simulierte Quantenfluktuation für Exploration"""
        return np.random.normal(0, 0.1) * np.exp(-1j*np.random.random())
