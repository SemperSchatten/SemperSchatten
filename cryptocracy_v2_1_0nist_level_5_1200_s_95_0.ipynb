import cmath # Für komplexe Zahlen in den Hilfsfunktionen
import math # Für mathematische Funktionen in den Hilfsfunktionen
from qiskit.transpiler import transpile # Für Qiskit Transpiler
from qiskit.visualization import plot_histogram # Für Qiskit Plotting
