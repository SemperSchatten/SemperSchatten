        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import matplotlib.patches as patches\n",
        "import plotly.graph_objects as go # Sicherstellen, dass plotly importiert ist\n",
        "\n",
        "def read_obj_file(file_path):\n",
        "    vertices = []\n",
        "    texture_coords = []\n",
        "    normals = []\n",
        "\n",
        "    with open(file_path, 'r') as file:\n",
        "        for line in file:\n",
        "            if line.startswith('v '):\n",
        "                vertices.append(list(map(float, line.strip().split()[1:])))\n",
        "            elif line.startswith('vt '):\n",
        "                texture_coords.append(list(map(float, line.strip().split()[1:])))\n",
        "            elif line.startswith('vn '):\n",
        "                normals.append(list(map(float, line.strip().split()[1:])))\n",
        "    return vertices, texture_coords, normals\n",
        "\n",
        "def project_vertices(vertices):\n",
        "    # Beispielhafte Projektionsmatrix für eine orthogonale Projektion\n",
        "    projection_matrix = np.array([\n",
        "        [1, 0, 0],\n",
        "        [0, 1, 0]\n",
        "    ])\n",
        "    projected_vertices = []\n",
        "    for vertex in vertices:\n",
        "        projected_vertex = np.dot(projection_matrix, vertex)\n",
        "        projected_vertices.append(projected_vertex)\n",
        "    return projected_vertices\n",
        "\n",
        "# Create a dummy prototype.obj file for demonstration\n",
        "obj_content = \"\"\"\\\n",
        "v 1.0 1.0 1.0\n",
        "v -1.0 1.0 1.0\n",
        "v -1.0 -1.0 1.0\n",
        "v 1.0 -1.0 1.0\n",
        "v 1.0 1.0 -1.0\n",
        "v -1.0 1.0 -1.0\n",
        "v -1.0 -1.0 -1.0\n",
        "v 1.0 -1.0 -1.0\n",
        "vt 0.0 0.0\n",
        "vt 1.0 0.0\n",
        "vt 1.0 1.0\n",
        "vt 0.0 1.0\n",
        "vn 0.0 0.0 1.0\n",
        "vn 0.0 1.0 0.0\n",
        "vn 1.0 0.0 0.0\n",
        "vn 0.0 0.0 -1.0\n",
        "vn 0.0 -1.0 0.0\n",
        "vn -1.0 0.0 0.0\n",
        "f 1 2 3 4\n",
        "f 5 8 7 6\n",
        "f 1 5 6 2\n",
        "f 2 6 7 3\n",
        "f 3 7 8 4\n",
        "f 4 8 5 1\n",
        "\"\"\"\n",
        "with open('prototype.obj', 'w') as f:\n",
        "    f.write(obj_content)\n",
        "\n",
        "# Beispielaufruf\n",
        "vertices_obj, texture_coords_obj, normals_obj = read_obj_file('prototype.obj')\n",
        "print(\"\\n3D Model (OBJ) File Processing:\")\n",
        "print(\"Vertices:\", vertices_obj)\n",
        "print(\"Texture Coordinates:\", texture_coords_obj)\n",
        "print(\"Normals:\", normals_obj)\n",
        "\n",
        "# Projektion der Vertices auf die XY-Ebene\n",
        "vertices_obj_array = np.array(vertices_obj)\n",
        "projected_vertices_obj = project_vertices(vertices_obj_array)\n",
        "\n",
        "# Visualisierung der projizierten Vertices\n",
        "projected_vertices_obj = np.array(projected_vertices_obj)\n",
        "plt.figure() # New figure for this plot\n",
        "plt.scatter(projected_vertices_obj[:, 0], projected_vertices_obj[:, 1])\n",
        "plt.title('Projected Vertices from OBJ File')\n",
        "plt.xlabel('X')\n",
        "plt.ylabel('Y')\n",
        "plt.axis('equal') # Ensure equal aspect ratio\n",
        "plt.show()"
      ],
