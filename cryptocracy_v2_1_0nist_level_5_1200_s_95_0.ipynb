def plot_spacetime_grid(planck_units=True):
    if planck_units:
        dx, dt = 1.6e-35, 5.4e-44 # Planck-Länge und Planck-Zeit
    else:
        dx, dt = 1.0, 1.0 # Generisches Gitter

    x = np.arange(0, 10*dx, dx)
    t = np.arange(0, 10*dt, dt)
    X, T = np.meshgrid(x, t)

    fig = plt.figure()
    ax = fig.add_subplot(111, projection='3d')
    ax.scatter(X, T, np.zeros_like(X), s=10, c='blue', alpha=0.6)
    ax.set_title("Diskrete Raumzeit (Planck-Skala)" if planck_units else "Generisches Gitter")
    ax.set_xlabel("Raum (m)")
    ax.set_ylabel("Zeit (s)")
    ax.set_zlabel("Energie (arb. Einheiten)")
    plt.show()
