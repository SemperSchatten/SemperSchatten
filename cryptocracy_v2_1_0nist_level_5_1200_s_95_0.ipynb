import numpy as np

class Memory:
    def __init__(self, capacity=1000):
        self.short_term = np.zeros(capacity, dtype=object) # dtype=object für gemischte Typen
        self.long_term = {}
        self.idx = 0

    def store(self, thought: str, priority: float):
        """Speichere Gedanken mit Prioritätsgewichtung"""
        if priority > 0.8:
            self.long_term[thought] = priority
        else:
            if self.idx < capacity:
                self.short_term[self.idx] = (thought, priority)
            else:
                self.short_term[self.idx % capacity] = (thought, priority)
            self.idx += 1

    def retrieve(self, key: str):
        """Hole Gedächtnisinhalt mit rekurrenter Aktivierung"""
        if key in self.long_term:
            return self.long_term[key]
        return None
