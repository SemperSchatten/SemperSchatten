import numpy as np
from qiskit import Aer, execute
from qiskit import QuantumCircuit
from qiskit.providers.aer import StatevectorSimulator

# Berechnung der Werte für die ersten 100 n
def calculate_values(n_max):
    results = []
    for n in range(1, n_max + 1):
        value = (-2 * np.pi * np.math.factorial(n)) / n**3
        results.append((n, value))
    return results

# Quantenalgorithmus mit Qiskit
def run_quantum_algorithm(values):
    backend = Aer.get_backend('statevector_simulator')

    for n, value in values:
        qc = QuantumCircuit(1)
        qc.h(0)  # Beispielhafter Einsatz eines Hadamard-Gatters

        job = execute(qc, backend)
        result = job.result()
        statevector = result.get_statevector(qc)
        
        print(f"n = {n}, Value = {value}, Statevector = {statevector}")

# Hauptprogramm
if __name__ == "__main__":
    values = calculate_values(100)
    run_quantum_algorithm(values)
